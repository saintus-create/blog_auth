---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";

const title = "Search";
const description = "Search blog posts and projects with AI-powered semantic search.";
---

<Layout title={title} description={description}>
  <Container>
    <div style="padding: 64px 0; max-width: 680px; margin: 0 auto;">
      <h1 style="font-size: var(--text-40); font-weight: 700; margin-bottom: 8px; color: rgb(var(--text-1));">
        Search
      </h1>
      <p style="font-size: var(--text-16); color: rgb(var(--text-1)); opacity: 0.6; margin-bottom: 48px; line-height: var(--lh-body);">
        Search by keyword or ask the AI a question about the content.
      </p>

      <!-- Unified search bar — opens the modal -->
      <button
        data-open-search="keyword"
        style="
          display: flex;
          align-items: center;
          gap: 12px;
          width: 100%;
          padding: 16px 20px;
          background: rgb(var(--bg));
          border: 1.5px solid rgb(var(--border));
          border-radius: 980px;
          cursor: pointer;
          font-size: var(--text-16);
          color: rgb(var(--text-1));
          opacity: 0.6;
          text-align: left;
          margin-bottom: 16px;
          min-height: var(--target-spatial);
        "
      >
        <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M3.5 7C3.5 5.067 5.067 3.5 7 3.5C8.933 3.5 10.5 5.067 10.5 7C10.5 7.88461 10.1718 8.69256 9.63058 9.30876L9.30876 9.63058C8.69256 10.1718 7.88461 10.5 7 10.5C5.067 10.5 3.5 8.933 3.5 7ZM9.96544 11.0261C9.13578 11.6382 8.11014 12 7 12C4.23858 12 2 9.76142 2 7C2 4.23858 4.23858 2 7 2C9.76142 2 12 4.23858 12 7C12 8.11014 11.6382 9.13578 11.0261 9.96544L14.0303 12.9697L14.5607 13.5L13.5 14.5607L12.9697 14.0303L9.96544 11.0261Z" stroke="currentColor"/>
        </svg>
        Search posts and projects…
      </button>

      <button
        data-open-search="ai"
        style="
          display: flex;
          align-items: center;
          gap: 12px;
          width: 100%;
          padding: 16px 20px;
          background: rgb(var(--surface));
          border: 1.5px solid rgb(var(--border));
          border-radius: 980px;
          cursor: pointer;
          font-size: var(--text-16);
          color: rgb(var(--text-3));
          text-align: left;
          min-height: var(--target-spatial);
        "
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/>
        </svg>
        Ask AI a question…
      </button>

      <p style="margin-top: 24px; font-size: 0.875rem; color: rgb(var(--text-1)); opacity: 0.4; text-align: center;">
        Press <kbd style="font-family:monospace;padding:2px 6px;border:1px solid rgb(var(--border));border-radius:4px;">/</kbd> or <kbd style="font-family:monospace;padding:2px 6px;border:1px solid rgb(var(--border));border-radius:4px;">⌘K</kbd> from anywhere to open search
      </p>
    </div>
  </Container>
</Layout>
