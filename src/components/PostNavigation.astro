---
const { prevPost, nextPost } = Astro.props;
import { ChevronLeft, ChevronRight } from "@lucide/astro";
---

<div class="grid grid-cols-2 gap-1.5 sm:gap-3">
  {
    prevPost?.id ? (
      <a
        href={`/blog/${prevPost?.id}`}
        class="group relative flex flex-nowrap items-center rounded-lg border px-4 py-3 pl-10 no-underline transition-colors duration-300 ease-in-out"
        style="background-color: rgb(var(--surface)); border-color: rgb(var(--border)); color: rgb(var(--text-1)); border-width: var(--btn-border-width); border-radius: var(--btn-border-radius);"
      >
        <ChevronLeft class="icon absolute left-2 top-1/2 -translate-y-1/2 transition-transform duration-300 ease-in-out" style="color: rgb(var(--text-1));" />
        <div class="flex items-center text-sm">{prevPost?.data.title}</div>
      </a>
    ) : (
      <div class="invisible" />
    )
  }

  {
    nextPost?.id ? (
      <a
        href={`/blog/${nextPost?.id}`}
        class="group relative flex grow flex-row-reverse flex-nowrap items-center rounded-lg border px-4 py-4 pr-10 no-underline transition-colors duration-300 ease-in-out"
        style="background-color: rgb(var(--surface)); border-color: rgb(var(--border)); color: rgb(var(--text-1)); border-width: var(--btn-border-width); border-radius: var(--btn-border-radius);"
      >
        <ChevronRight class="icon absolute right-2 top-1/2 -translate-y-1/2 transition-transform duration-300 ease-in-out" style="color: rgb(var(--text-1));" />
        <div class="flex items-center text-sm">{nextPost?.data.title}</div>
      </a>
    ) : (
      <div class="invisible" />
    )
  }
</div>
