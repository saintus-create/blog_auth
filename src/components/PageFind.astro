---
import Search from "astro-pagefind/components/Search";
---

<aside data-pagefind-ignore>
  <div
    transition:persist
    id="backdrop"
    class="invisible fixed left-0 top-0 z-50 flex h-screen w-full items-start justify-center p-6"
    style="background: rgba(0,0,0,0.6); backdrop-filter: blur(8px);"
  >
    <div
      id="pagefind-container"
      style="
        margin-top: 80px;
        width: 100%;
        max-width: 600px;
        max-height: 80vh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        border-radius: 16px;
        border: 1.5px solid rgb(var(--border));
        background: rgb(var(--bg));
        box-shadow: 0 24px 64px rgba(0,0,0,0.3);
      "
    >
      <!-- Tab bar -->
      <div
        style="
          display: flex;
          gap: 0;
          border-bottom: 1.5px solid rgb(var(--border));
          flex-shrink: 0;
        "
      >
        <button
          id="keyword-search-btn"
          class="search-tab-btn search-tab-active"
          aria-label="Keyword search"
        >
          Keyword
        </button>
        <button
          id="ai-search-btn"
          class="search-tab-btn"
          aria-label="AI search"
        >
          Ask AI
        </button>
        <div style="flex:1;"></div>
        <button
          id="close-search-btn"
          aria-label="Close search"
          style="
            padding: 0 20px;
            background: none;
            border: none;
            cursor: pointer;
            color: rgb(var(--text-1));
            font-size: 1.25rem;
            opacity: 0.5;
          "
        >✕</button>
      </div>

      <!-- Keyword panel -->
      <div id="keyword-search-panel" style="overflow-y: auto; padding: 12px 16px 8px;">
        <Search
          id="search"
          className="pagefind-ui"
          uiOptions={{
            showImages: false,
            excerptLength: 20,
            resetStyles: false,
          }}
        />
      </div>

      <!-- AI panel -->
      <div id="ai-search-panel" style="display:none; overflow-y: auto; padding: 16px;">
        <div style="display:flex; gap:8px; margin-bottom:12px;">
          <input
            type="text"
            id="ai-search-input"
            placeholder="Ask anything about the content…"
            autocomplete="off"
            style="
              flex: 1;
              padding: 12px 16px;
              border: 1.5px solid rgb(var(--border));
              border-radius: 980px;
              font-size: 1rem;
              background: rgb(var(--bg));
              color: rgb(var(--text-1));
              outline: none;
              min-height: 48px;
            "
          />
          <button
            id="ai-search-submit"
            style="
              padding: 12px 20px;
              background: rgb(var(--surface));
              color: rgb(var(--text-3));
              border: none;
              border-radius: 980px;
              cursor: pointer;
              font-size: 0.9375rem;
              font-weight: 600;
              min-height: 48px;
              white-space: nowrap;
            "
          >Search</button>
        </div>
        <div id="ai-search-results"></div>
      </div>

      <!-- Footer hint -->
      <div
        style="
          padding: 8px 16px;
          text-align: right;
          font-size: 0.8125rem;
          color: rgb(var(--text-1));
          opacity: 0.45;
          border-top: 1px solid rgb(var(--border));
          flex-shrink: 0;
        "
      >
        Press <kbd style="font-family:monospace; font-size:0.75rem; padding:1px 4px; border:1px solid rgb(var(--border)); border-radius:4px;">Esc</kbd> or click outside to close
      </div>
    </div>
  </div>
</aside>

<script is:inline>
  const backdrop = document.getElementById("backdrop");
  const keywordSearchBtn = document.getElementById("keyword-search-btn");
  const aiSearchBtn = document.getElementById("ai-search-btn");
  const closeSearchBtn = document.getElementById("close-search-btn");
  const keywordSearchPanel = document.getElementById("keyword-search-panel");
  const aiSearchPanel = document.getElementById("ai-search-panel");
  const aiSearchInput = document.getElementById("ai-search-input");
  const aiSearchSubmit = document.getElementById("ai-search-submit");
  const aiSearchResults = document.getElementById("ai-search-results");

  function openSearch(mode) {
    backdrop.classList.remove("invisible");
    backdrop.classList.add("visible");
    if (mode === "ai") {
      switchToAI();
    } else {
      switchToKeyword();
    }
  }

  function closeSearch() {
    backdrop.classList.remove("visible");
    backdrop.classList.add("invisible");
    const searchInput = document.querySelector("#search input");
    if (searchInput) searchInput.value = "";
    if (aiSearchInput) aiSearchInput.value = "";
    if (aiSearchResults) aiSearchResults.innerHTML = "";
  }

  function switchToKeyword() {
    keywordSearchBtn.classList.add("search-tab-active");
    aiSearchBtn.classList.remove("search-tab-active");
    keywordSearchPanel.style.display = "";
    aiSearchPanel.style.display = "none";
    const searchInput = document.querySelector("#search input");
    if (searchInput) setTimeout(() => searchInput.focus(), 50);
  }

  function switchToAI() {
    aiSearchBtn.classList.add("search-tab-active");
    keywordSearchBtn.classList.remove("search-tab-active");
    aiSearchPanel.style.display = "";
    keywordSearchPanel.style.display = "none";
    if (aiSearchInput) setTimeout(() => aiSearchInput.focus(), 50);
  }

  function escapeHtml(str) {
    const d = document.createElement("div");
    d.textContent = str;
    return d.innerHTML;
  }

  async function performAISearch() {
    const query = aiSearchInput?.value?.trim();
    if (!query) return;

    aiSearchResults.innerHTML = `
      <div style="padding:24px;text-align:center;opacity:0.6;font-size:0.9375rem;">
        Searching…
      </div>
    `;

    try {
      const res = await fetch("/api/ai-chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ messages: [{ role: "user", content: query }] }),
      });

      if (!res.ok) throw new Error(res.statusText);

      const data = await res.json();
      const answer = data.choices?.[0]?.message?.content || data.response || "";
      const snippets = data.data ?? [];

      let html = "";

      if (answer) {
        html += `
          <div style="
            padding: 16px;
            border-radius: 12px;
            background: rgb(var(--surface));
            color: rgb(var(--text-3));
            margin-bottom: 16px;
            font-size: 1rem;
            line-height: 1.75;
          ">
            <div style="font-weight:600;margin-bottom:8px;font-size:0.8125rem;opacity:0.7;text-transform:uppercase;letter-spacing:0.05em;">AI Answer</div>
            ${escapeHtml(answer)}
          </div>
        `;
      }

      if (snippets.length > 0) {
        html += `<div style="font-weight:600;margin-bottom:8px;font-size:0.8125rem;opacity:0.6;text-transform:uppercase;letter-spacing:0.05em;">Related</div>`;
        snippets.forEach(function(s) {
          const filename = s.content?.filename || s.attributes?.filename || "";
          const text = s.content?.text || "";
          const url = s.attributes?.url || (filename ? "/" + filename.replace(/\.md$/, "") : "");
          html += `
            <div
              class="ai-result-item"
              data-url="${escapeHtml(String(url))}"
              style="
                padding: 12px 14px;
                border-radius: 10px;
                border: 1px solid rgb(var(--border));
                margin-bottom: 8px;
                cursor: pointer;
              "
            >
              ${filename ? `<div style="font-weight:600;font-size:0.9375rem;margin-bottom:4px;">${escapeHtml(filename)}</div>` : ""}
              ${text ? `<div style="font-size:0.875rem;opacity:0.7;line-height:1.6;">${escapeHtml(text.slice(0, 180))}${text.length > 180 ? "…" : ""}</div>` : ""}
            </div>
          `;
        });
      }

      if (!answer && snippets.length === 0) {
        html = `<div style="padding:24px;text-align:center;opacity:0.5;">No results found. Try a different query.</div>`;
      }

      aiSearchResults.innerHTML = html;

      aiSearchResults.querySelectorAll(".ai-result-item").forEach(function(el) {
        el.addEventListener("click", function() {
          const url = el.getAttribute("data-url");
          if (url && url !== "") window.location.href = url;
        });
        el.addEventListener("mouseenter", function() {
          el.style.background = "rgb(var(--surface))";
          el.style.color = "rgb(var(--text-3))";
        });
        el.addEventListener("mouseleave", function() {
          el.style.background = "";
          el.style.color = "";
        });
      });

    } catch (err) {
      aiSearchResults.innerHTML = `
        <div style="padding:16px;color:#ef4444;font-size:0.9375rem;">
          Search failed. Please try again.<br>
          <span style="opacity:0.6;font-size:0.8125rem;">${escapeHtml(String(err))}</span>
        </div>
      `;
    }
  }

  keywordSearchBtn?.addEventListener("click", switchToKeyword);
  aiSearchBtn?.addEventListener("click", switchToAI);
  closeSearchBtn?.addEventListener("click", closeSearch);
  aiSearchSubmit?.addEventListener("click", performAISearch);
  aiSearchInput?.addEventListener("keydown", function(e) {
    if (e.key === "Enter") { e.preventDefault(); performAISearch(); }
  });

  // Open from header search link / magnifying glass
  document.addEventListener("click", function(e) {
    const trigger = e.target.closest("[data-open-search]");
    if (trigger) {
      e.preventDefault();
      openSearch(trigger.dataset.openSearch || "keyword");
    }
    const magnifyingGlass = document.getElementById("magnifying-glass");
    if (magnifyingGlass && (e.target === magnifyingGlass || magnifyingGlass.contains(e.target))) {
      openSearch("keyword");
    }
  });

  document.addEventListener("keydown", function(e) {
    if (e.key === "Escape") { closeSearch(); return; }
    if (e.key === "/" && !["INPUT","TEXTAREA"].includes(document.activeElement?.tagName)) {
      e.preventDefault();
      openSearch("keyword");
    }
    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      e.preventDefault();
      openSearch("keyword");
    }
  });

  backdrop?.addEventListener("click", function(e) {
    if (!e.target.closest("#pagefind-container")) closeSearch();
  });

  // Also expose openSearch globally for inline scripts on other pages
  window.__openSearch = openSearch;
</script>

<style is:global>
  :root {
    --pagefind-ui-scale: 0.85;
    --pagefind-ui-border-width: 1.5px;
    --pagefind-ui-border-radius: 10px;
    --pagefind-ui-font: "Geist Sans", ui-sans-serif, system-ui, sans-serif;
    --pagefind-ui-primary: rgb(28, 28, 28);
    --pagefind-ui-text: rgb(28, 28, 28);
    --pagefind-ui-background: rgb(229, 229, 229);
    --pagefind-ui-border: rgb(28, 28, 28);
    --pagefind-ui-tag: rgb(28, 28, 28);
  }

  .dark {
    --pagefind-ui-primary: rgb(229, 229, 229);
    --pagefind-ui-text: rgb(229, 229, 229);
    --pagefind-ui-background: rgb(28, 28, 28);
    --pagefind-ui-border: rgb(229, 229, 229);
    --pagefind-ui-tag: rgb(229, 229, 229);
  }

  @media (prefers-color-scheme: dark) {
    :root:not(.light) {
      --pagefind-ui-primary: rgb(229, 229, 229);
      --pagefind-ui-text: rgb(229, 229, 229);
      --pagefind-ui-background: rgb(28, 28, 28);
      --pagefind-ui-border: rgb(229, 229, 229);
      --pagefind-ui-tag: rgb(229, 229, 229);
    }
  }

  #search input {
    font-weight: 400;
    font-size: 1rem;
    min-height: 48px;
  }

  #search p { font-weight: 400; }
  #search .pagefind-ui__result-title { font-weight: 600; }
  #search .pagefind-ui__message { padding: 0; padding-bottom: 0.75rem; }

  .search-tab-btn {
    padding: 14px 20px;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.9375rem;
    font-weight: 500;
    color: rgb(var(--text-1));
    opacity: 0.45;
    transition: opacity 0.15s;
    border-bottom: 2px solid transparent;
    margin-bottom: -1.5px;
  }

  .search-tab-btn:hover {
    opacity: 0.75;
  }

  .search-tab-active {
    opacity: 1;
    border-bottom-color: rgb(var(--text-1));
  }
</style>
