---
import Search from "astro-pagefind/components/Search";
---

<aside data-pagefind-ignore>
  <div
    transition:persist
    id="backdrop"
    class="bg-[rgba(0, 0, 0, 0.5] invisible fixed left-0 top-0 z-50 flex h-screen w-full justify-center p-6 backdrop-blur-xs"
  >
    <div
      id="pagefind-container"
      class="m-0 flex h-fit max-h-[80%] w-full max-w-(--breakpoint-sm) flex-col overflow-auto rounded-sm border border-[#C1C1C1] bg-[#E5E5E5] p-2 px-4 py-3 shadow-lg"
    >
      <div class="search-mode-toggle mb-2 flex gap-2">
        <button id="keyword-search-btn" class="mode-btn active">Keyword Search</button>
        <button id="ai-search-btn" class="mode-btn">AI Search</button>
      </div>
      
      <div id="keyword-search-panel">
        <Search
          id="search"
          className="pagefind-ui"
          uiOptions={{
            showImages: false,
            excerptLength: 15,
            resetStyles: false,
          }}
        />
      </div>
      
      <div id="ai-search-panel" class="hidden">
        <div class="ai-search-input-wrapper">
          <input
            type="text"
            id="ai-search-input"
            placeholder="Ask a question about the content..."
            class="ai-search-input"
          />
          <button id="ai-search-submit" class="ai-search-submit">Search</button>
        </div>
        <div id="ai-search-results" class="ai-search-results"></div>
      </div>
      
      <div class="mr-2 pb-1 pt-4 text-right text-xs dark:prose-invert">
        Press <span class="prose text-xs dark:prose-invert"
          ><kbd class="">Esc</kbd></span
        > or click anywhere to close
      </div>
    </div>
  </div>
</aside>

<script lang="ts">
  const magnifyingGlass = document.getElementById("magnifying-glass");
  const backdrop = document.getElementById("backdrop");
  const keywordSearchBtn = document.getElementById("keyword-search-btn");
  const aiSearchBtn = document.getElementById("ai-search-btn");
  const keywordSearchPanel = document.getElementById("keyword-search-panel");
  const aiSearchPanel = document.getElementById("ai-search-panel");
  const aiSearchInput = document.getElementById("ai-search-input");
  const aiSearchSubmit = document.getElementById("ai-search-submit");
  const aiSearchResults = document.getElementById("ai-search-results");

  function openPagefind() {
    const searchDiv = document.getElementById("search");
    const search = searchDiv.querySelector("input");
    setTimeout(() => {
      search.focus();
    }, 0);
    backdrop?.classList.remove("invisible");
    backdrop?.classList.add("visible");
  }

  function closePagefind() {
    const search = document.getElementById("search");
    search.value = "";
    backdrop?.classList.remove("visible");
    backdrop?.classList.add("invisible");
  }

  // Toggle between keyword and AI search
  keywordSearchBtn?.addEventListener("click", () => {
    keywordSearchBtn?.classList.add("active");
    aiSearchBtn?.classList.remove("active");
    keywordSearchPanel?.classList.remove("hidden");
    aiSearchPanel?.classList.add("hidden");
  });

  aiSearchBtn?.addEventListener("click", () => {
    aiSearchBtn?.classList.add("active");
    keywordSearchBtn?.classList.remove("active");
    aiSearchPanel?.classList.remove("hidden");
    keywordSearchPanel?.classList.add("hidden");
    aiSearchInput?.focus();
  });

  // AI search functionality
  async function performAISearch() {
    const query = aiSearchInput?.value?.trim();
    if (!query) return;

    aiSearchResults!.innerHTML = '<div class="ai-search-loading">Searching...</div>';

    try {
      const response = await fetch('/api/ai-search', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ query }),
      });

      if (!response.ok) {
        throw new Error('Search failed');
      }

      const data = await response.json();
      displayAISearchResults(data);
    } catch (error) {
      console.error('AI search error:', error);
      aiSearchResults!.innerHTML = '<div class="ai-search-error">Search failed. Please try again.</div>';
    }
  }

  function displayAISearchResults(results: any) {
    if (!results || results.length === 0) {
      aiSearchResults!.innerHTML = '<div class="ai-search-no-results">No results found</div>';
      return;
    }

    aiSearchResults!.innerHTML = results.map((result: any) => `
      <div class="ai-search-result" data-url="${result.url || '#'}">
        <div class="ai-search-result-title">${result.title || 'Untitled'}</div>
        <div class="ai-search-result-snippet">${result.snippet || result.content || ''}</div>
      </div>
    `).join('');

    document.querySelectorAll('.ai-search-result').forEach(item => {
      item.addEventListener('click', () => {
        const url = item.getAttribute('data-url');
        if (url && url !== '#') {
          window.location.href = url;
        }
      });
    });
  }

  aiSearchSubmit?.addEventListener('click', performAISearch);
  aiSearchInput?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      performAISearch();
    }
  });

  // open pagefind
  magnifyingGlass?.addEventListener("click", () => {
    openPagefind();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "/") {
      e.preventDefault();
      openPagefind();
    } else if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      e.preventDefault();
      openPagefind();
    }
  });

  // close pagefind
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      closePagefind();
    }
  });

  // close pagefind when searched result(link) clicked
  document.addEventListener("click", (event) => {
    if (event.target.classList.contains("pagefind-ui__result-link") || 
        event.target.classList.contains("ai-search-result")) {
      closePagefind();
    }
  });

  backdrop?.addEventListener("click", (event) => {
    if (!event.target.closest("#pagefind-container")) {
      closePagefind();
    }
  });

  // prevent form submission
  const form = document.getElementById("form");
  form?.addEventListener("submit", (event) => {
    event.preventDefault();
  });
</script>

<style is:global>
  :root {
    --pagefind-ui-scale: 0.75;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 3px;
    --pagefind-ui-font: "Geist", sans-serif;
    --pagefind-ui-primary: #282828;
    --pagefind-ui-text: #282828;
    --pagefind-ui-background: #E5E5E5;
    --pagefind-ui-border: #C1C1C1;
    --pagefind-ui-tag: #C1C1C1;
  }

  .dark {
    --pagefind-ui-primary: #282828;
    --pagefind-ui-text: #282828;
    --pagefind-ui-background: #C1C1C1;
    --pagefind-ui-border: #E5E5E5;
  }

  #search input {
    font-weight: normal;
  }

  #search p {
    font-weight: normal;
  }

  #search .pagefind-ui__result-title {
    font-weight: 600;
  }

  #search .pagefind-ui__message {
    padding: 0;
    padding-bottom: 0.75rem;
  }

  .search-mode-toggle {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .mode-btn {
    flex: 1;
    padding: 0.5rem 1rem;
    background-color: transparent;
    border: 1px solid #C1C1C1;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 500;
    color: #282828;
    transition: all 0.2s;
  }

  .mode-btn:hover {
    background-color: rgba(0, 0, 0, 0.05);
  }

  .mode-btn.active {
    background-color: #282828;
    color: #E5E5E5;
    border-color: #282828;
  }

  .ai-search-input-wrapper {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .ai-search-input {
    flex: 1;
    padding: 0.75rem;
    border: 1px solid #C1C1C1;
    border-radius: 4px;
    font-size: 0.875rem;
    background-color: #E5E5E5;
    color: #282828;
    outline: none;
  }

  .ai-search-input:focus {
    border-color: #282828;
  }

  .ai-search-submit {
    padding: 0.75rem 1.25rem;
    background-color: #282828;
    color: #E5E5E5;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 500;
    transition: opacity 0.2s;
  }

  .ai-search-submit:hover {
    opacity: 0.9;
  }

  .ai-search-results {
    max-height: 300px;
    overflow-y: auto;
  }

  .ai-search-result {
    padding: 0.75rem;
    border-bottom: 1px solid #C1C1C1;
    cursor: pointer;
    transition: background-color 0.2s;
  }

  .ai-search-result:hover {
    background-color: rgba(0, 0, 0, 0.05);
  }

  .ai-search-result:last-child {
    border-bottom: none;
  }

  .ai-search-result-title {
    font-weight: 600;
    color: #282828;
    margin-bottom: 0.25rem;
  }

  .ai-search-result-snippet {
    font-size: 0.875rem;
    color: #666;
    line-height: 1.5;
  }

  .ai-search-loading,
  .ai-search-error,
  .ai-search-no-results {
    padding: 1rem;
    text-align: center;
    color: #666;
  }

  .ai-search-error {
    color: #dc2626;
  }

  .hidden {
    display: none;
  }
</style>
